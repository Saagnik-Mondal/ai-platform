# ================================================
# ML Sentinel — Environment Configuration (Example)
# Copy this to .env and update the values
# ================================================

# PostgreSQL
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=ml_sentinel
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://sentinel:your_password_here@postgres:5432/ml_sentinel

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
MLFLOW_BACKEND_STORE_URI=postgresql+psycopg2://sentinel:your_password_here@postgres:5432/mlflow
MLFLOW_DEFAULT_ARTIFACT_ROOT=s3://mlflow-artifacts/

# MinIO (S3-compatible artifact storage)
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=your_minio_password
AWS_ACCESS_KEY_ID=minio_admin
AWS_SECRET_ACCESS_KEY=your_minio_password

# API
MODEL_NAME=fraud-detector
API_HOST=0.0.0.0
API_PORT=8000

# Drift Detection
DRIFT_CHECK_INTERVAL_MINUTES=5
DRIFT_THRESHOLD=0.5
REFERENCE_DATA_SIZE=5000
CURRENT_DATA_WINDOW=1000

# Retraining
RETRAIN_MIN_SAMPLES=500
RETRAIN_IMPROVEMENT_THRESHOLD=0.01

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=your_grafana_password
GF_USERS_ALLOW_SIGN_UP=false
